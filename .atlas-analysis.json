  "keyFeatures": [
    "Discord bot directory with search and filtering",
    "Server listing and discovery platform",
    "Emoji library with categorization and download",
    "Sound effects library for Discord",
    "Server templates marketplace",
    "Profile themes and customization",
    "Premium membership system",
    "REST API with authentication",
    "Real-time statistics and analytics",
    "Review and rating system",
    "User authentication via Discord OAuth2",
    "Dashboard for managing submissions"
  ],
  "publicApiSurface": [
    "PATCH /bots/{id}/stats - Update bot statistics",
    "GET /emojis - List emojis",
    "GET /emojis/{id} - Get emoji details",
    "GET /servers - List servers",
    "GET /servers/{id} - Get server details",
    "GET /sounds - List sounds",
    "GET /sounds/{id} - Get sound details",
    "GET /templates - List templates",
    "GET /templates/{id} - Get template details",
    "GET /profiles/{id} - Get user profile",
    "POST /auth/login - Discord OAuth2 authentication",
    "GET /auth/callback - OAuth2 callback",
    "POST /auth/refresh - Refresh authentication token"
  ]
